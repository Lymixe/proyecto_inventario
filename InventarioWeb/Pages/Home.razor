@page "/home"
@attribute [Authorize]
@inject NavigationManager Nav

<!-- TOPBAR -->
<div class="topbar">
    <div class="topbar-brand">
        <div class="topbar-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <rect x="3" y="3" width="7" height="7" rx="1.5" fill="white" opacity="0.9"/>
                <rect x="14" y="3" width="7" height="7" rx="1.5" fill="white" opacity="0.5"/>
                <rect x="3" y="14" width="7" height="7" rx="1.5" fill="white" opacity="0.5"/>
                <rect x="14" y="14" width="7" height="7" rx="1.5" fill="white" opacity="0.7"/>
            </svg>
        </div>
        <span class="topbar-title">CONTROL INVENTARIO — TI-FMH</span>
    </div>

    <div class="topbar-right">
        <div class="topbar-user">
            <div class="user-avatar">AD</div>
            <div>
                <div class="user-name">Administrador</div>
                <div class="user-role">Informática</div>
            </div>
        </div>
        <button class="btn-logout" @onclick="CerrarSesion">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Cerrar sesión
        </button>
    </div>
</div>

<!-- CONTENIDO -->
<div class="home-page">
    <div class="home-content">

        <div class="home-greeting">
            <h1>Bienvenido, Administrador 👋</h1>
            <p>Selecciona un módulo para comenzar</p>
        </div>

        <div class="modules-grid">

            <div class="module-card" @onclick='() => Nav.NavigateTo("/usuarios")'>
                <div class="module-icon icon-blue">
                    <svg width="32" height="32" fill="none" stroke="#1a4fa0" stroke-width="1.5" viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <div class="module-label">GESTIONAR USUARIOS</div>
                <div class="module-desc">Crear, editar y asignar equipos al personal</div>
            </div>

            <div class="module-card" @onclick='() => Nav.NavigateTo("/inventario")'>
                <div class="module-icon icon-teal">
                    <svg width="32" height="32" fill="none" stroke="#0f6e56" stroke-width="1.5" viewBox="0 0 24 24">
                        <rect x="2" y="3" width="20" height="14" rx="2"/>
                        <path d="M8 21h8M12 17v4"/>
                        <path d="M6 8h.01M9 8h6"/>
                        <path d="M6 11h.01M9 11h6"/>
                    </svg>
                </div>
                <div class="module-label">GESTIONAR INVENTARIO</div>
                <div class="module-desc">Registrar, editar y dar de baja equipos</div>
            </div>

            <div class="module-card" @onclick='() => Nav.NavigateTo("/requerimientos")'>
                <div class="module-icon icon-amber">
                    <svg width="32" height="32" fill="none" stroke="#ba7517" stroke-width="1.5" viewBox="0 0 24 24">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                </div>
                <div class="module-label">GESTIONAR REQUERIMIENTOS</div>
                <div class="module-desc">Reportes de problemas del personal</div>
            </div>

            <div class="module-card" @onclick='() => Nav.NavigateTo("/software")'>
                <div class="module-icon icon-purple">
                    <svg width="32" height="32" fill="none" stroke="#534ab7" stroke-width="1.5" viewBox="0 0 24 24">
                        <rect x="2" y="3" width="20" height="14" rx="2"/>
                        <polyline points="8 21 12 17 16 21"/>
                        <polyline points="9 9 12 12 15 9"/>
                    </svg>
                </div>
                <div class="module-label">GESTIONAR SOFTWARE</div>
                <div class="module-desc">Licencias y software instalado</div>
            </div>

        </div>
    </div>
</div>

@code {
    private void CerrarSesion()
    {
        Nav.NavigateTo("/login");
    }
}